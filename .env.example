# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NextAuth ──────────────────────────────────────────────
NEXTAUTH_SECRET=generate-a-random-32-char-secret
NEXTAUTH_URL=http://localhost:3000

# ── FastAPI (internal) ────────────────────────────────────
FASTAPI_INTERNAL_URL=http://localhost:8000

# ── FastAPI Python-side (.env in /backend) ────────────────
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-xxx.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
ENCRYPTION_KEY=generate-a-base64-encoded-32-byte-key
